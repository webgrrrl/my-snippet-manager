{
  "name": "my-snippet-manager",
  "displayName": "Snippet Manager",
  "description": "Save, organize, and reuse code snippets across any programming language",
  "version": "1.0.0",
  "publisher": "webgrrrl",
  "repository": {
    "type": "git",
    "url": "https://github.com/webgrrrl/my-snippet-manager"
  },
  "homepage": "https://github.com/webgrrrl/my-snippet-manager/blob/main/README.md",
  "bugs": {
    "url": "https://github.com/webgrrrl/my-snippet-manager/issues"
  },
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "snippetsTreeView",
          "name": "My Snippets"
        }
      ]
    },
    "commands": [
      {
        "command": "my-snippet-manager.saveSnippet",
        "title": "Save Selection as Snippet"
      },
      {
        "command": "my-snippet-manager.deleteSnippet",
        "title": "Delete Snippet"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "my-snippet-manager.saveSnippet",
          "when": "view == snippetsTreeView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "my-snippet-manager.deleteSnippet",
          "when": "view == snippetsTreeView",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "20.x",
    "typescript": "^5.3.0"
  }
}