{
  "name": "my-snippet-manager",
  "displayName": "Snippet Manager",
  "description": "Manage code snippets",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:snippetsTreeView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "snippetsTreeView",
          "name": "My Snippets"
        }
      ]
    },
    "commands": [
      {
        "command": "my-snippet-manager.saveSnippet",
        "title": "Save Selection as Snippet"
      },
      {
        "command": "my-snippet-manager.deleteSnippet",
        "title": "Delete Snippet"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "my-snippet-manager.saveSnippet",
          "when": "view == snippetsTreeView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "my-snippet-manager.deleteSnippet",
          "when": "view == snippetsTreeView",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "20.x",
    "typescript": "^5.3.0"
  }
}